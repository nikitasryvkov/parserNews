# Поднятие стека при загрузке сервера (Docker Compose).
# Скопируйте: sudo cp parser-news-docker.service.example /etc/systemd/system/parser-news.service
# Правки: User, WorkingDirectory, путь к docker compose.
#
# sudo systemctl daemon-reload
# sudo systemctl enable parser-news.service
# sudo systemctl start parser-news.service

[Unit]
Description=ParserNews (Docker Compose)
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/parser-news
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
