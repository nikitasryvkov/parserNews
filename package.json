{
  "name": "parser-news",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node -e \"const fs=require('fs');if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true})\" && tsc",
    "start": "node dist/index.js",
    "dev": "cross-env USE_RAW_CACHE=1 tsx watch src/index.ts",
    "migrate": "tsx ./node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.js",
    "infra": "docker compose up -d redis postgres",
    "test:tadviser": "tsx scripts/test-tadviser.ts",
    "test:ria": "tsx scripts/test-ria.ts",
    "test:smartranking": "tsx scripts/test-smartranking.ts",
    "run:smartranking": "tsx scripts/run-smartranking.ts"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.0",
    "knex": "^3.0.0",
    "multer": "^2.1.1",
    "p-limit": "^5.0.0",
    "pg": "^8.11.0",
    "pino": "^10.3.1",
    "puppeteer": "^21.0.0",
    "tsx": "^4.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.0.0"
  }
}
