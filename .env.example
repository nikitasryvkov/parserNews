# Server
PORT=3000
# Слушать на всех интерфейсах (нужно в Docker; по умолчанию в коде уже 0.0.0.0)
# LISTEN_HOST=0.0.0.0
LOG_LEVEL=info

# Auth
# AUTH_PROVIDER=api_key
# For AUTH_PROVIDER=api_key:
API_KEY=
# For AUTH_PROVIDER=keycloak:
# KEYCLOAK_URL=https://sso.example.com
# KEYCLOAK_REALM=parser-news
# KEYCLOAK_CLIENT_ID=parser-news-web
# KEYCLOAK_ADMIN_CLIENT_ID=parser-news-admin
# KEYCLOAK_ADMIN_CLIENT_SECRET=

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=parser_news
DB_USER=postgres
# Required in production. Example for local dev only: postgres
DB_PASSWORD=
# DB_POOL_MAX=10
# DB_POOL_IDLE_MS=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Кэш raw: 1 — для большинства парсеров брать из data/raw/{parser}/, не ходить на сайт.
# Парсер ria всегда ходит в сеть (кэш для него отключён), иначе залипает на старых 20 новостях.
USE_RAW_CACHE=1

# РИА: число порций ленты (1-я — главная, дальше more.html, ~20 новостей на порцию). См. дашборд / app_settings.
# RIA_LENTA_PAGES=5
# RIA_PAGE_DELAY_MS=350
# RIA_PUPPETEER_SETTLE_MS=2000
